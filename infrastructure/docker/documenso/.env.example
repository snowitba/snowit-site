# Documenso Environment Variables
# Copy this file to .env and fill in the values

DOCUMENSO_DB_PASSWORD=your_secure_password_here
DOCUMENSO_ENCRYPTION_KEY=generate_random_32_char_key_here
DOCUMENSO_SECONDARY_KEY=generate_random_32_char_key_here

# SES SMTP Credentials (generate after terraform apply)
SES_SMTP_USERNAME=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password
